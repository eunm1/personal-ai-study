// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PostStatus {
  PENDING
  ANALYZING
  GENERATING
  COMPLETED
  FAILED
}

model Post {
  id Int @id @default(autoincrement())

  title String
  content String @db.Text

  searchIndex String @default("")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // (필드 추가 2026.03.20)
  author    String        // 작성자 이름
  password  String        // 암호화된 비밀번호가 저장될 공간
  analysis  PostAnalysis?

  categoryId Int?  // AI가 분류한 카테고리
  category   Category? @relation(fields: [categoryId], references: [id])
}

model Category {
  id Int @id @default(autoincrement())
  name  String @unique
  posts Post[]
  //'대괄호([])'는 리스트(배열)를 의미합니다.
  // 하나의 카테고리 아래에 여러 개의 게시글이 매칭될 수 있다는 1:N(일대다) 관계를 설정하는 부분
}

//(테이블 추가 2026.03.20)
model PostAnalysis {
  id           Int        @id @default(autoincrement())
  post         Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId       Int        @unique 

  style        String?    //이미지 생성 스타일 
  
  summary      String?    @db.Text
  imagePrompt  String?    @db.Text
  tempImageUrl String?    // Leonardo 임시 주소 (재시도용)
  imageUrl     String?    // Supabase 영구 주소
  
  status       PostStatus @default(PENDING)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
